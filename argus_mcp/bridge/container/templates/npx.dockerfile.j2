{# NPX Dockerfile template — multi-stage build for Node.js MCP packages.
   Rendered by the Jinja2 engine with a TemplateData context.
   Variables: builder_image, is_alpine, build_env, package, package_clean,
              bin_name, system_deps, additional_packages, container_uid,
              container_user, container_home.
#}
# Auto-generated by Argus MCP — do not edit.
FROM {{ builder_image }} AS builder
WORKDIR /app
{% for key, value in build_env.items() %}
ARG {{ key }}="{{ value }}"
ENV {{ key }}="${{ '{' }}{{ key }}{{ '}' }}"
{% endfor %}
RUN npm install --save {{ package }}
# Discover the canonical binary name from the installed package.
# NPM packages define binaries in package.json "bin" field, which
# may differ from the package name (e.g. gemini-mcp-tool -> gemini-mcp,
# @modelcontextprotocol/server-sequential-thinking -> mcp-server-sequential-thinking).
# Strategy: try heuristic name first, then read package.json, then ls fallback.
RUN BIN_NAME="{{ bin_name }}" \
    && test -f "/app/node_modules/.bin/$BIN_NAME" \
    || BIN_NAME=$(node -p '(p=require("{{ package_clean }}/package.json"),b=p.bin,n=typeof b==="string"?p.name.replace(/^@[^/]+[/]/,""):b?Object.keys(b)[0]:"",n||process.exit(1),n)' 2>/dev/null) \
    || BIN_NAME=$(ls /app/node_modules/.bin/ | head -1) \
    && test -f "/app/node_modules/.bin/$BIN_NAME" \
    || (echo "ERROR: no binary found for '{{ package_clean }}'. Available:" && ls /app/node_modules/.bin/ && exit 1) \
    && ln -sf "$BIN_NAME" /app/node_modules/.bin/__argus_entry \
    && echo "Resolved binary: $BIN_NAME"

FROM {{ builder_image }}
WORKDIR /app
COPY --from=builder /app/node_modules /app/node_modules
ENV NODE_PATH=/app/node_modules \
    NODE_ENV=production \
    PATH="/app/node_modules/.bin:$PATH"
{% if system_deps %}
{% if is_alpine %}
RUN apk add --no-cache {{ system_deps | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ system_deps | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
{% if additional_packages %}
{% if is_alpine %}
RUN apk add --no-cache {{ additional_packages | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ additional_packages | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
RUN (adduser -D -u {{ container_uid }} -h {{ container_home }} {{ container_user }} 2>/dev/null || adduser --disabled-password --uid {{ container_uid }} --home {{ container_home }} {{ container_user }}) \
    && mkdir -p {{ container_home }} \
    && chown {{ container_user }}:{{ container_user }} {{ container_home }}
ENV HOME={{ container_home }} TMPDIR=/tmp
USER {{ container_user }}
ENTRYPOINT ["/app/node_modules/.bin/__argus_entry"]
