{# UVX Dockerfile template — multi-stage build for Python MCP packages.
   Rendered by the Jinja2 engine with a TemplateData context.
   Variables: builder_image, is_alpine, build_env, install_cmd, binary,
              system_deps, additional_packages, container_uid,
              container_user, container_home.
#}
# syntax=docker/dockerfile:1
# Auto-generated by Argus MCP — do not edit.
FROM {{ builder_image }} AS builder
{% if is_alpine %}
RUN apk add --no-cache python3 py3-pip
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip python3-venv && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --break-system-packages uv 2>/dev/null || pip install uv
{% for key, value in build_env.items() %}
ARG {{ key }}="{{ value }}"
ENV {{ key }}="${{ '{' }}{{ key }}{{ '}' }}"
{% endfor %}
{% if build_system_deps %}
{% if is_alpine %}
RUN apk add --no-cache {{ build_system_deps | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ build_system_deps | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
ENV UV_TOOL_DIR=/opt/uv-tools
ENV UV_TOOL_BIN_DIR=/opt/uv-tools/bin
RUN --mount=type=cache,target=/root/.cache/uv \
    mkdir -p /opt/uv-tools/bin && {{ install_cmd }}
# Expose dependency binaries — uv tool install only symlinks the
# top-level package entry points into UV_TOOL_BIN_DIR.  Dependencies
# (e.g. ruff for mcp-server-analyzer) live in the tool's venv bin dir.
# Symlink any missing executables so they are on PATH at runtime.
RUN for bin in /opt/uv-tools/*/bin/*; do \
      [ -x "$bin" ] && [ ! -e "/opt/uv-tools/bin/$(basename "$bin")" ] && \
      ln -s "$bin" "/opt/uv-tools/bin/$(basename "$bin")" || true; \
    done

FROM {{ builder_image }}
COPY --from=builder /opt/uv-tools /opt/uv-tools
ENV PATH="/opt/uv-tools/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1
{% if system_deps %}
{% if is_alpine %}
RUN apk add --no-cache {{ system_deps | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ system_deps | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
{% if additional_packages %}
{% if is_alpine %}
RUN apk add --no-cache {{ additional_packages | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ additional_packages | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
RUN (adduser --disabled-password --uid {{ container_uid }} --home {{ container_home }} {{ container_user }} 2>/dev/null || adduser -D -u {{ container_uid }} -h {{ container_home }} {{ container_user }}) \
    && mkdir -p {{ container_home }} \
    && chown {{ container_user }}:{{ container_user }} {{ container_home }}
ENV HOME={{ container_home }} TMPDIR=/tmp
USER {{ container_user }}
LABEL argus.image="true"
ENTRYPOINT ["{{ binary }}"]
