FROM {{ builder_image }} AS builder
WORKDIR /src
{% for key, value in build_env.items() %}
ARG {{ key }}="{{ value }}"
ENV {{ key }}="${{ '{' }}{{ key }}{{ '}' }}"
{% endfor %}
{% if build_system_deps %}
{% if is_alpine %}
RUN apk add --no-cache {{ build_system_deps | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ build_system_deps | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
{% if source_url_host %}
# Private repo auth via .netrc (uses GIT_AUTH_TOKEN if set)
RUN if [ -n "${GIT_AUTH_TOKEN:-}" ]; then \
      printf 'machine {{ source_url_host }}\nlogin x-access-token\npassword %s\n' "$GIT_AUTH_TOKEN" > /root/.netrc && \
      chmod 600 /root/.netrc; \
    fi
{% endif %}
RUN git clone --depth 1 {{ '--branch ' + source_ref + ' ' if source_ref }}{{ source_url }} /src/repo
WORKDIR /src/repo
{% if source_url_host %}
RUN rm -f /root/.netrc
{% endif %}
{% for step in build_steps %}
RUN {{ step }}
{% endfor %}

FROM {{ builder_image }}
WORKDIR /app
{% if not is_alpine %}
# Carry over pip-installed packages and console-script binaries.
COPY --from=builder /usr/local/lib/ /usr/local/lib/
COPY --from=builder /usr/local/bin/ /usr/local/bin/
{% else %}
COPY --from=builder /usr/local/ /usr/local/
{% endif %}
COPY --from=builder /src/repo /app
{% if system_deps %}
{% if is_alpine %}
RUN apk add --no-cache {{ system_deps | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ system_deps | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
{% if additional_packages %}
{% if is_alpine %}
RUN apk add --no-cache {{ additional_packages | join(' ') }}
{% else %}
RUN apt-get update && \
    apt-get install -y --no-install-recommends {{ additional_packages | join(' ') }} && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
{% endif %}
RUN (adduser --disabled-password --uid {{ container_uid }} --home {{ container_home }} {{ container_user }} 2>/dev/null || adduser -D -u {{ container_uid }} -h {{ container_home }} {{ container_user }}) \
    && mkdir -p {{ container_home }} \
    && chown {{ container_user }}:{{ container_user }} {{ container_home }}
ENV HOME={{ container_home }} TMPDIR=/tmp
USER {{ container_user }}
LABEL argus.image="true"
ENTRYPOINT [{% for part in entrypoint %}"{{ part }}"{% if not loop.last %}, {% endif %}{% endfor %}]
