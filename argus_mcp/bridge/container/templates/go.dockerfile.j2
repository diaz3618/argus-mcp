{# Go Dockerfile template — multi-stage build for Go MCP packages.
   Rendered by the Jinja2 engine with a TemplateData context.
   Variables: builder_image, build_env, go_package, go_package_clean,
              system_deps, additional_packages, runtime_args,
              container_uid, container_user, container_home.

   Pattern:
   - Builder stage compiles from source with `go install`
   - Runtime stage is minimal Alpine with the single binary
   - Non-root user for security
#}
# Auto-generated by Argus MCP — do not edit.
FROM {{ builder_image }} AS builder
{% for key, value in build_env.items() %}
ENV {{ key }}="{{ value }}"
{% endfor %}

# Install build dependencies
{% if build_system_deps %}
{% if additional_packages %}
RUN apk add --no-cache {{ additional_packages | join(' ') }} {{ build_system_deps | join(' ') }}
{% else %}
RUN apk add --no-cache ca-certificates git {{ build_system_deps | join(' ') }}
{% endif %}
{% elif additional_packages %}
RUN apk add --no-cache {{ additional_packages | join(' ') }}
{% else %}
RUN apk add --no-cache ca-certificates git
{% endif %}

# Set environment variables for reproducible static builds
ENV CGO_ENABLED=0 \
    GOOS=linux \
    GO111MODULE=on

WORKDIR /build

# Install the Go package — handles versioned and unversioned specifiers.
# If no @version is present, @latest is appended automatically.
RUN package="{{ go_package }}"; \
    if ! echo "$package" | grep -q '@'; then \
        package="${package}@latest"; \
    fi; \
    mkdir -p /app && \
    go install "$package" && \
    mv $GOPATH/bin/* /app/mcp-server 2>/dev/null || \
    find $GOPATH/bin -type f -executable -exec mv {} /app/mcp-server \; 2>/dev/null || \
    (base_package=$(echo "$package" | sed 's/@.*//'); \
     go get "$package" && go build -o /app/mcp-server "$base_package")

# Final stage — minimal runtime image
FROM alpine:3.21

# Runtime dependencies only
RUN apk add --no-cache ca-certificates

WORKDIR /app

# Create a non-root user (UID {{ container_uid }} — distroless/Chainguard standard)
RUN addgroup -g {{ container_uid }} -S {{ container_user }} && \
    adduser -u {{ container_uid }} -S {{ container_user }} -G {{ container_user }} -h {{ container_home }} && \
    mkdir -p /app {{ container_home }} && \
    chown -R {{ container_user }}:{{ container_user }} /app {{ container_home }}
ENV HOME={{ container_home }} TMPDIR=/tmp
{% if system_deps %}

# System dependencies from backend config
RUN apk add --no-cache {{ system_deps | join(' ') }}
{% endif %}

# Copy the pre-built binary from builder stage
COPY --from=builder --chown={{ container_user }}:{{ container_user }} /app/mcp-server /app/mcp-server

# Switch to non-root user
USER {{ container_user }}

# Run the pre-built MCP server binary
ENTRYPOINT ["/app/mcp-server"{% for arg in runtime_args %}, "{{ arg }}"{% endfor %}]
